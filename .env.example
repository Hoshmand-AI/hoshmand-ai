# Waitlist Form Configuration
# Choose ONE option:

# Option 1: Formspree (recommended - simple and free)
# Get your form ID from https://formspree.io
# FORMSPREE_FORM_ID=your_form_id

# Option 2: ConvertKit (for email marketing features)
# Get your form ID and API key from https://convertkit.com
# CONVERTKIT_FORM_ID=your_form_id
# CONVERTKIT_API_KEY=your_api_key

# Option 3: Direct action URL (any form endpoint)
# NEXT_PUBLIC_WAITLIST_ACTION=https://formspree.io/f/your_form_id
